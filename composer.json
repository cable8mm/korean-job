{
    "name": "cable8mm/korean-job",
    "type": "project",
    "description": "This project is intended for both Korean employees and employers.",
    "keywords": [
        "jpb",
        "website",
        "employee",
        "empolyer"
    ],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "blade-ui-kit/blade-heroicons": "^2.2",
        "guzzlehttp/guzzle": "^7.2",
        "laravel-lang/locales": "^2.5",
        "laravel/framework": "^12.0.0",
        "laravel/nova": "5.7.7",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.11",
        "laravel/tinker": "^2.9",
        "livewire/livewire": "^3.4",
        "mcamara/laravel-localization": "dev-master",
        "socialiteproviders/facebook": "^4.1",
        "socialiteproviders/github": "^4.1",
        "socialiteproviders/google": "^4.1",
        "socialiteproviders/instagram": "^5.0",
        "socialiteproviders/kakao": "^4.2",
        "socialiteproviders/naver": "^4.1"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.14",
        "barryvdh/laravel-ide-helper": "^3.2",
        "fakerphp/faker": "^1.9.1",
        "laravel-lang/common": "^6.1",
        "laravel/breeze": "^2.0",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan lang:update",
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "test": [
            "./vendor/bin/phpunit tests"
        ],
        "lint": [
            "./vendor/bin/pint"
        ],
        "migrate": [
            "@php artisan migrate:fresh --seed"
        ],
        "clear": [
            "@php artisan cache:clear",
            "@php artisan config:clear",
            "@php artisan route:clear",
            "@php artisan view:clear"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [ ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://nova.laravel.com"
        }
    ]
}
